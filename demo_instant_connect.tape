Output demo_instant_connect.gif

  Set Padding 16
  Set FontFamily "Geist Mono"
  Set TypingSpeed 100ms
  Set FontSize 16
  Set Width 1000
  Set Height 580

  Sleep 333ms
  Type "dssh skylink"
  Sleep 500ms
  Enter

  Sleep 1250ms
  Set TypingSpeed 50ms
  Type "echo WOW DSSH IS SO COOL I WISH I HAD THIS SOONER"
  Enter
  Sleep 1s
  Set TypingSpeed 100ms
  Type "exit"
  Enter
  Sleep 2s
