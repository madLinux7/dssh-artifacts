Output demo_config.gif

  Set Padding 16
  Set FontFamily "Geist Mono"
  Set TypingSpeed 100ms
  Set FontSize 16
  Set Width 1000
  Set Height 480

  Type "dssh config"
  Sleep 500ms
  Enter
  Sleep 1s
  Down
  Sleep 1s
  Down
  Sleep 1s
  Enter
  Sleep 1.25s
  Down
  Sleep 500ms
  Down
  Sleep 500ms
  Type "~/.ssh/custom-config"
  Sleep 500ms
  Enter
  Sleep 2s
